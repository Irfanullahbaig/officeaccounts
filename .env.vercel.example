# =============================================================================
# N9Accounts — Vercel + Supabase (recommended production setup)
# =============================================================================
# Copy each value into Vercel → Project → Settings → Environment Variables
# =============================================================================

# --- Supabase Auth (login) ---
NEXT_PUBLIC_SUPABASE_URL=https://rzeouxflwqiprffkdccs.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Legacy JWT anon key also works:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Legacy alias:
# SUPABASE_SECRET_KEY=your-service-role-key

# --- Supabase Postgres (employees, loans, savings, etc.) ---
# Shared pooler — host: aws-1-ap-northeast-1.pooler.supabase.com, port 6543
# Do NOT wrap values in quotes in the Vercel dashboard.
DATABASE_URL=postgresql://postgres.rzeouxflwqiprffkdccs:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session pooler — port 5432 (migrations / prisma db push)
DATABASE_URL_UNPOOLED=postgresql://postgres.rzeouxflwqiprffkdccs:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# --- App session cookie (signs n9_session after Supabase login) ---
SESSION_SECRET=your-long-random-session-secret

# --- Bootstrap admin (created on first /api/setup) ---
ADMIN_EMAIL=admin@northnine.pk
ADMIN_PASSWORD=N9Accounts@123

NEXT_PUBLIC_APP_URL=https://YOUR_APP.vercel.app
NEXT_PUBLIC_APP_NAME=N9Accounts

# =============================================================================
# After first deploy, run once in browser:
# https://YOUR_APP.vercel.app/api/setup?secret=YOUR_SUPABASE_SERVICE_ROLE_KEY
# =============================================================================
