# =============================================================================
# N9Accounts — Vercel production environment variables
# =============================================================================
# Copy each line into: Vercel → Project → Settings → Environment Variables
# Enable for: Production (+ Preview if you use preview deploys)
#
# After saving, redeploy (Deployments → ⋯ → Redeploy). NEXT_PUBLIC_* vars are
# embedded at build time — a redeploy is required after changing them.
# =============================================================================

# --- Supabase project (Settings → API) ---------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://rzeouxflwqiprffkdccs.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_YOUR_KEY

# Server-only — never expose in client code (Settings → API → secret / service_role)
SUPABASE_SECRET_KEY=sb_secret_REPLACE_WITH_YOUR_KEY

# Optional explicit API bases (auto-derived from NEXT_PUBLIC_SUPABASE_URL if omitted)
SUPABASE_AUTH_URL=https://rzeouxflwqiprffkdccs.supabase.co/auth/v1
SUPABASE_REST_URL=https://rzeouxflwqiprffkdccs.supabase.co/rest/v1

# Legacy aliases (use only if you have JWT-style keys instead of sb_* keys)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Database (Settings → Database → Connection string → URI) ----------------
# Use "Transaction" pooler (port 6543) for serverless / Vercel:
DATABASE_URL=postgresql://postgres.rzeouxflwqiprffkdccs:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional alias
# SUPABASE_DB_URL=postgresql://...

# --- OAuth (optional) --------------------------------------------------------
NEXT_PUBLIC_OAUTH_PROVIDERS=google

# --- App URLs (replace with your real Vercel domain) -------------------------
NEXT_PUBLIC_APP_URL=https://YOUR_APP.vercel.app
NEXT_PUBLIC_APP_NAME=N9Accounts

# --- One-time setup route (/api/setup?secret=...) ----------------------------
# Defaults to SUPABASE_SECRET_KEY if unset
# SETUP_SECRET=your-setup-secret

# --- Default admin (created by /api/setup) -----------------------------------
# DEFAULT_ADMIN_EMAIL=admin@northnine.pk
# DEFAULT_ADMIN_PASSWORD=N9Accounts@123
