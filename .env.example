# =============================================================================
# N9Accounts — local development
# Copy:  cp .env.example .env.local
# =============================================================================

# Local database (optional on Vercel — leave unset for static auth)
DATABASE_URL="file:./dev.db"

SESSION_SECRET="change-this-to-a-long-random-string"

# Static login (used when DATABASE_URL is unset, e.g. on Vercel)
ADMIN_EMAIL="admin@northnine.pk"
ADMIN_PASSWORD="N9Accounts@123"

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=N9Accounts
