# =============================================================================
# N9Accounts — local development
# Copy:  cp .env.example .env.local
# =============================================================================

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Session signing secret (change in production)
SESSION_SECRET="change-this-to-a-long-random-string"
AUTH_SECRET="change-this-to-a-long-random-string"

# Optional default admin (created on first run / setup)
# DEFAULT_ADMIN_EMAIL="admin@northnine.pk"
# DEFAULT_ADMIN_PASSWORD="N9Accounts@123"

# Optional one-time setup route: /api/setup?secret=YOUR_SETUP_SECRET
# SETUP_SECRET="your-setup-secret"

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=N9Accounts
