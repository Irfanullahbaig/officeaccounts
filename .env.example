# =============================================================================
# N9Accounts — local development (.env.local)
# Copy:  cp .env.example .env.local
# Vercel: see .env.vercel.example
# =============================================================================

# Supabase — Auth + API (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SECRET_KEY="your-supabase-secret-key"
SUPABASE_REST_URL="https://YOUR_PROJECT_REF.supabase.co/rest/v1"
SUPABASE_AUTH_URL="https://YOUR_PROJECT_REF.supabase.co/auth/v1"

# OAuth on login pages (comma-separated: google, github, azure, apple)
NEXT_PUBLIC_OAUTH_PROVIDERS=google

# Legacy key aliases (still supported)
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database
# Local dev (SQLite file — no Supabase Postgres required):
DATABASE_URL="file:./dev.db"

# Production / Supabase Postgres (Vercel — use pooler URI, port 6543):
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# SUPABASE_DB_URL="postgresql://..."

# Optional admin bootstrap overrides
# DEFAULT_ADMIN_EMAIL="admin@northnine.pk"
# DEFAULT_ADMIN_PASSWORD="N9Accounts@123"

# Optional one-time setup route secret (defaults to SUPABASE_SECRET_KEY)
# SETUP_SECRET="your-setup-secret"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=N9Accounts
